%  EXERCISE 3.9
% =============================================================
\exercise{3.9}

\textbf{(a)}\; What is the smallest integer $k$ such that $\sqrt{n} = O(n^k)$?

By definition, $\sqrt{n} = n^{0.5}$. We want the smallest integer $k$ such that $n^{0.5} \le c\,n^k$ for $n \ge n_0$.
Since $k$ must be an integer:
\begin{itemize}
    \item For $k = 0$: $n^0 = 1$, which does not upper-bound $n^{0.5}$.
    \item For $k = 1$: $n^1 = n$. Since $n^{0.5} \le n$ for all $n \ge 1$, we have $\sqrt{n} \in O(n^1)$.
\end{itemize}
Therefore, the smallest integer is
\[
    \boxed{k = 1}
\]

\bigskip

\textbf{(b)}\; What is the smallest integer $k$ such that $n \log n = O(n^k)$?

We need the smallest integer $k$ such that $n \log n \le c\,n^k$ for $n \ge n_0$.
\begin{itemize}
    \item For $k = 1$: We would need $n \log n \le c\,n \implies \log n \le c$, which is false for unbounded $n$. Thus, $n \log n \notin O(n)$.
    \item For $k = 2$: We need $n \log n \le c\,n^2 \implies \log n \le c\,n$. We know that logarithmic growth is strictly slower than linear growth. For instance, $\log_2 n \le n$ for all $n \ge 1$. Thus, $n \log n \in O(n^2)$.
\end{itemize}
Therefore, the smallest integer is
\[
    \boxed{k = 2}
\]

% =============================================================
%  EXERCISE 3.10
% =============================================================
\exercise{3.10}

\textbf{(a)}\; Is $2n = \Theta(3n)$? Explain why or why not.

\textbf{Yes.} For $2n \in \Theta(3n)$, we must find positive constants $c_1, c_2,$ and $n_0$ such that:
\[
    c_1(3n) \le 2n \le c_2(3n) \quad \text{for all } n \ge n_0.
\]
Dividing by $n$ (for $n \ge 1$), we get:
\[
    3 c_1 \le 2 \le 3 c_2
\]
This requires $c_1 \le \frac{2}{3}$ and $c_2 \ge \frac{2}{3}$.
We can choose $c_1 = \frac{1}{2}$, $c_2 = 1$, and $n_0 = 1$. The inequalities $\frac{3}{2} \le 2 \le 3$ hold true. Thus, $\boxed{2n \in \Theta(3n)}$.

\bigskip

\textbf{(b)}\; Is $2^n = \Theta(3^n)$? Explain why or why not.

\textbf{No.} For $2^n \in \Theta(3^n)$ to be true, there must exist positive constants $c_1, c_2,$ and $n_0$ such that:
\[
    c_1(3^n) \le 2^n \le c_2(3^n) \quad \text{for all } n \ge n_0.
\]
Focusing on the lower bound, dividing both sides by $3^n$ gives:
\[
    c_1 \le \left(\frac{2}{3}\right)^n
\]
Since $\frac{2}{3} < 1$, as $n \to \infty$, the term $\left(\frac{2}{3}\right)^n \to 0$. In order for the inequality to hold for all arbitrarily large $n$, $c_1$ would have to be $\le 0$. However, by definition, $c_1$ must be a strictly positive constant ($c_1 > 0$). Since no such constant can exist, $2^n$ is not bounded below by a positive multiple of $3^n$. Thus, $\boxed{2^n \notin \Theta(3^n)}$.

% =============================================================
%  EXERCISE 3.11
% =============================================================
\exercise{3.11}

In Section 3.4.5, the Method of Limits states that we compute $L = \lim_{n \to \infty} \frac{f(n)}{g(n)}$.
\begin{itemize}
    \item If $0 < L < \infty$, then $f(n) \in \Theta(g(n))$.
    \item If $L = 0$, then $f(n) \in O(g(n))$ (but not $\Theta$).
    \item If $L = \infty$, then $f(n) \in \Omega(g(n))$ (but not $\Theta$).
\end{itemize}

\bigskip

\textbf{(a)}\; $f(n) = \log n^2$; $g(n) = \log n + 5$
\[
    L = \lim_{n \to \infty} \frac{\log n^2}{\log n + 5} = \lim_{n \to \infty} \frac{2 \log n}{\log n + 5} = \lim_{n \to \infty} \frac{2}{1 + \frac{5}{\log n}} = 2
\]
Since $0 < L < \infty$, $\boxed{f(n) \in \Theta(g(n))}$.

\medskip

\textbf{(b)}\; $f(n) = \sqrt{n}$; $g(n) = \log n^2$
\[
    L = \lim_{n \to \infty} \frac{\sqrt{n}}{2 \log n} = \infty
\]
(By L'H\^opital's Rule, $\lim \frac{\frac{1}{2\sqrt{n}}}{2/n} = \lim \frac{n}{4\sqrt{n}} = \lim \frac{\sqrt{n}}{4} = \infty$).
Since $L = \infty$, $\boxed{f(n) \in \Omega(g(n))}$.

\medskip

\textbf{(c)}\; $f(n) = \log^2 n$; $g(n) = \log n$
\[
    L = \lim_{n \to \infty} \frac{(\log n)^2}{\log n} = \lim_{n \to \infty} \log n = \infty
\]
Since $L = \infty$, $\boxed{f(n) \in \Omega(g(n))}$.

\medskip

\textbf{(d)}\; $f(n) = n$; $g(n) = \log^2 n$
\[
    L = \lim_{n \to \infty} \frac{n}{(\log n)^2} = \infty
\]
(Polynomials grow faster than any power of logarithms).
Since $L = \infty$, $\boxed{f(n) \in \Omega(g(n))}$.

\medskip

\textbf{(e)}\; $f(n) = n \log n + n$; $g(n) = \log n$
\[
    L = \lim_{n \to \infty} \frac{n \log n + n}{\log n} = \lim_{n \to \infty} \left(n + \frac{n}{\log n}\right) = \infty
\]
Since $L = \infty$, $\boxed{f(n) \in \Omega(g(n))}$.

\medskip

\textbf{(f)}\; $f(n) = \log n^2$; $g(n) = (\log n)^2$
\[
    L = \lim_{n \to \infty} \frac{2 \log n}{(\log n)^2} = \lim_{n \to \infty} \frac{2}{\log n} = 0
\]
Since $L = 0$, $\boxed{f(n) \in O(g(n))}$.

\medskip

\textbf{(g)}\; $f(n) = 10$; $g(n) = \log 10$
\[
    L = \lim_{n \to \infty} \frac{10}{\log 10} = c \approx 4.34
\]
Since $0 < L < \infty$ (both are constants), $\boxed{f(n) \in \Theta(g(n))}$.

\medskip

\textbf{(h)}\; $f(n) = 2^n$; $g(n) = 10n^2$
\[
    L = \lim_{n \to \infty} \frac{2^n}{10n^2} = \infty
\]
(Exponentials grow strictly faster than polynomials).
Since $L = \infty$, $\boxed{f(n) \in \Omega(g(n))}$.

\medskip

\textbf{(i)}\; $f(n) = 2^n$; $g(n) = n \log n$
\[
    L = \lim_{n \to \infty} \frac{2^n}{n \log n} = \infty
\]
(Exponentials grow strictly faster than $n \log n$).
Since $L = \infty$, $\boxed{f(n) \in \Omega(g(n))}$.

\medskip

\textbf{(j)}\; $f(n) = 2^n$; $g(n) = 3^n$
\[
    L = \lim_{n \to \infty} \frac{2^n}{3^n} = \lim_{n \to \infty} \left(\frac{2}{3}\right)^n = 0
\]
Since $L = 0$, $\boxed{f(n) \in O(g(n))}$.

\medskip

\textbf{(k)}\; $f(n) = 2^n$; $g(n) = n^n$
\[
    L = \lim_{n \to \infty} \frac{2^n}{n^n} = \lim_{n \to \infty} \left(\frac{2}{n}\right)^n = 0
\]
Since $L = 0$, $\boxed{f(n) \in O(g(n))}$.

% =============================================================
%  EXERCISE 3.12
% =============================================================
\exercise{3.12}

\textbf{(a)}
\begin{verbatim}
  a = b + c;
  d = a + e;
\end{verbatim}
This consists of two basic, constant-time operations. The runtime is unaffected by any input size $n$.
\[
    \boxed{\Theta(1)}
\]

\medskip

\textbf{(b)}
\begin{verbatim}
  sum = 0;
  for (i=0; i<3; i++)
    for (j=0; j<n; j++)
      sum++;
\end{verbatim}
The inner loop executes $n$ times. The outer loop executes a constant 3 times. The total number of operations is $3n$.
\[
    \boxed{\Theta(n)}
\]

\medskip

\textbf{(c)}
\begin{verbatim}
  sum=0;
  for (i=0; i<n*n; i++)
    sum++;
\end{verbatim}
The loop executes exactly $n^2$ times.
\[
    \boxed{\Theta(n^2)}
\]

\medskip

\textbf{(d)}
\begin{verbatim}
  for (i=0; i < n-1; i++)
    for (j=i+1; j < n; j++) {
      ...
    }
\end{verbatim}
The outer loop goes from $0$ to $n-2$. The inner loop iterates $n - 1 - i$ times. The total number of iterations is the sum of the first $n-1$ integers: $\sum_{i=1}^{n-1} i = \frac{n(n-1)}{2} \approx \frac{1}{2}n^2$.
\[
    \boxed{\Theta(n^2)}
\]

\medskip

\textbf{(e)}
\begin{verbatim}
  sum = 0;
  for (i=1; i<=n; i++)
    for (j=1; j<=n; j*=2)
      sum++;
\end{verbatim}
The inner loop doubles $j$ each iteration, running $\approx \log_2 n$ times. The outer loop runs $n$ times. The total number of iterations is $n \log_2 n$.
\[
    \boxed{\Theta(n \log n)}
\]

\medskip

\textbf{(f)}
\begin{verbatim}
  sum = 0;
  for (i=1; i<=n; i*=2)
    for (j=1; j<=n; j++)
      sum++;
\end{verbatim}
The outer loop doubles $i$ each iteration, running $\approx \log_2 n$ times. The inner loop iterates $n$ times during each outer loop. Total iterations: $n \log_2 n$.
\[
    \boxed{\Theta(n \log n)}
\]

\medskip

\textbf{(g)}
\begin{verbatim}
  for (i=0; i<n; i++) {
    for (j=0; j<n; j++)
      A[j] = Random(n);
    sort(A, n);
  }
\end{verbatim}
Inside the outer loop, the inner loop takes $\Theta(n)$ time. The \texttt{sort} function takes $\Theta(n \log n)$ time. Therefore, each iteration of the outer loop takes $\Theta(n + n \log n) = \Theta(n \log n)$ time. The outer loop runs $n$ times, yielding a total runtime of $n \times \Theta(n \log n)$.
\[
    \boxed{\Theta(n^2 \log n)}
\]

\medskip

\textbf{(h)}
\begin{verbatim}
  sum = 0;
  for (i=0; i<n; i++)
    for (j=0; A[j]!=i; j++)
      sum++;
\end{verbatim}
Array $A$ contains a random permutation of values from $0$ to $n-1$. The inner loop acts as a linear search for the value $i$. On average, the inner loop will examine half the array before finding $i$, executing $n/2$ iterations. Over $n$ total searches, the average total iterations is $n \times (n/2) = \frac{1}{2}n^2$.
\[
    \boxed{\Theta(n^2)}
\]

\medskip

\textbf{(i)}
\begin{verbatim}
  sum = 0;
  if (EVEN(n))
    for (i=0; i<n; i++)
      sum++;
  else
    sum = sum + n;
\end{verbatim}
When $n$ is EVEN, the loop runs $n$ times: $\Theta(n)$. When $n$ is ODD, no loop runs: $\Theta(1)$. In the average case, we assume there is an equal probability of $n$ being EVEN or ODD. The expected average runtime is therefore $\frac{c_1 n + c_2}{2}$, which scales linearly with $n$.
\[
    \boxed{\Theta(n)}
\]

