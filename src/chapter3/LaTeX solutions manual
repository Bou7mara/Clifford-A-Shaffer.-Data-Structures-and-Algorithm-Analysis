\exercise{3.4}

A new machine is $64\times$ faster.  For each complexity, find the new
problem size~$n'$ solvable in the same time.

\bigskip

\textbf{(a)}\; $T(n)=3\cdot 2^{n}$
\[
    \frac{3 \cdot 2^{n'}}{64} = 3 \cdot 2^{n}
    \;\Longrightarrow\;
    2^{n'} = 2^{n+6}
    \;\Longrightarrow\;
    \boxed{n' = n + 6}
\]

\textbf{(b)}\; $T(n)=n^{2}$
\[
    \frac{(n')^{2}}{64} = n^{2}
    \;\Longrightarrow\;
    (n')^{2} = 64\,n^{2}
    \;\Longrightarrow\;
    \boxed{n' = 8n}
\]

\textbf{(c)}\; $T(n)=8n$
\[
    \frac{8n'}{64} = 8n
    \;\Longrightarrow\;
    n' = 64n
    \;\Longrightarrow\;
    \boxed{n' = 64n}
\]




% =============================================================
%  EXERCISE 3.5
% =============================================================
\exercise{3.5}


\textbf{Setup.}\;
Let $T$ denote the growth-rate function of the algorithm.
Prunes solves size~$n$ in one hour, so $T(n)$ units of work fill one
hour on Prunes.  XYZ is $100\times$ faster, so in one hour it performs
$100\,T(n)$ units of work.  We need $n'$ such that
\[
    T(n') = 100\,T(n).
\]

\bigskip

\textbf{(a)}\; $T(n)=n$
\[
    n' = 100\,n
    \;\Longrightarrow\;
    \boxed{n' = 100n}
\]

\textbf{(b)}\; $T(n)=n^{2}$
\[
    (n')^{2} = 100\,n^{2}
    \;\Longrightarrow\;
    n' = \sqrt{100}\,n
    \;\Longrightarrow\;
    \boxed{n' = 10n}
\]

\textbf{(c)}\; $T(n)=n^{3}$
\[
    (n')^{3} = 100\,n^{3}
    \;\Longrightarrow\;
    n' = \sqrt[3]{100}\,n
    \;\Longrightarrow\;
    \boxed{n' = 100^{1/3}\,n \approx 4.64\,n}
\]

\textbf{(d)}\; $T(n)=2^{n}$
\[
    2^{n'} = 100 \cdot 2^{n}
    \;\Longrightarrow\;
    n' = n + \log_2 100
    \;\Longrightarrow\;
    \boxed{n' \approx n + 6.64}
\]

\medskip
Observation: For polynomial-time algorithms, the speed-up \emph{multiplies} the
solvable input size by a constant factor.  For the exponential algorithm
$2^{n}$, it only \emph{adds} a constant ($\approx 6.64$)---a much
smaller improvement, illustrating why exponential algorithms scale so
poorly.



% =============================================================
%  EXERCISE 3.6
% =============================================================
\exercise{3.6}

\textbf{Setup.}\;
We seek a growth-rate function $T(n)$ with a specific self-squaring
(or self-cubing) property when the input size is doubled.
We try the ansatz $T(n) = 2^{n^{k}}$ and solve for~$k$.

\bigskip

\textbf{(a)}\; Find $T$ such that $T(2n) = \bigl[T(n)\bigr]^{2}$.

Let $T(n) = 2^{n^{k}}$.  Then
\[
    T(2n) = 2^{(2n)^{k}} = 2^{2^{k}\,n^{k}},
    \qquad
    \bigl[T(n)\bigr]^{2} = 2^{2\,n^{k}}.
\]
Equating exponents:
\[
    2^{k}\,n^{k} = 2\,n^{k}
    \;\Longrightarrow\;
    2^{k} = 2
    \;\Longrightarrow\;
    k = 1.
\]
\[
    \boxed{T(n) = 2^{n}}
\]

\smallskip
\textit{Verification:}\;
$T(2n) = 2^{2n} = \bigl(2^{n}\bigr)^{2} = \bigl[T(n)\bigr]^{2}.\;\checkmark$

\bigskip

\textbf{(b)}\; Find $T$ such that $T(2n) = \bigl[T(n)\bigr]^{3}$.

Again let $T(n) = 2^{n^{k}}$.  Then
\[
    T(2n) = 2^{(2n)^{k}} = 2^{2^{k}\,n^{k}},
    \qquad
    \bigl[T(n)\bigr]^{3} = 2^{3\,n^{k}}.
\]
Equating exponents:
\[
    2^{k}\,n^{k} = 3\,n^{k}
    \;\Longrightarrow\;
    2^{k} = 3
    \;\Longrightarrow\;
    k = \log_{2} 3.
\]
\[
    \boxed{T(n) = 2^{\,n^{\log_{2} 3}}}
\]

\smallskip
\textit{Verification:}\;
$T(2n) = 2^{(2n)^{\log_2 3}}
       = 2^{2^{\log_2 3}\,n^{\log_2 3}}
       = 2^{3\,n^{\log_2 3}}
       = \bigl(2^{n^{\log_2 3}}\bigr)^{3}
       = \bigl[T(n)\bigr]^{3}.\;\checkmark$



% =============================================================
%  EXERCISE 3.7
% =============================================================
\exercise{3.7}

\textbf{Definition (Big-Oh).}\;
$f(n) \in O(g(n))$ if and only if there exist positive constants $c$
and $n_0$ such that
\[
    f(n) \;\le\; c\,g(n) \quad \text{for all } n \ge n_0.
\]

\bigskip

\textbf{(a)}\; Show that $1 \in O(1)$.

\textit{Proof.}\;
Let $f(n) = 1$ and $g(n) = 1$.  Choose $c = 1$ and $n_0 = 1$.
Then for all $n \ge 1$:
\[
    f(n) = 1 \;\le\; 1 \cdot 1 = c\,g(n).
\]
The condition of the definition is satisfied, so
\[
    \boxed{1 \in O(1).} \qquad \checkmark
\]

\bigskip

\textbf{(b)}\; Show that $1 \in O(n)$.

\textit{Proof.}\;
Let $f(n) = 1$ and $g(n) = n$.  Choose $c = 1$ and $n_0 = 1$.
Then for all $n \ge 1$:
\[
    f(n) = 1 \;\le\; n = 1 \cdot n = c\,g(n),
\]
since $n \ge 1$ for all $n \ge n_0 = 1$.
The condition is satisfied, so
\[
    \boxed{1 \in O(n).} \qquad \checkmark
\]

\medskip
\textit{Remark.}\;
This illustrates that big-Oh is an \emph{upper bound}, not a tight one.
A constant function is trivially dominated by a linear one, so membership
in $O(n)$ is a weaker (less informative) claim than membership in $O(1)$.



