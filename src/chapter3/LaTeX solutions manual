%  EXERCISE 3.13
% =============================================================
\exercise{3.13}

Show that big-Theta notation ($\Theta$) defines an equivalence relation on the set of functions.

\textbf{Proof:} To show that $\Theta$ defines an equivalence relation, we must demonstrate that it is reflexive, symmetric, and transitive.

\begin{enumerate}
    \item \textbf{Reflexivity} ($f(n) \in \Theta(f(n))$):
    For any $n \ge 1$, it is trivially true that:
    \[
        1 \cdot f(n) \le f(n) \le 1 \cdot f(n)
    \]
    We can choose constants $c_1 = 1$, $c_2 = 1$, and $n_0 = 1$. Both conditions hold, so reflexivity is satisfied.

    \item \textbf{Symmetry} (If $f(n) \in \Theta(g(n))$, then $g(n) \in \Theta(f(n))$):
    If $f(n) \in \Theta(g(n))$, there exist positive constants $c_1, c_2,$ and $n_0$ such that for all $n \ge n_0$:
    \[
        c_1 g(n) \le f(n) \le c_2 g(n)
    \]
    By dividing both inequalities by $c_1$ and $c_2$ respectively, we obtain:
    \[
        \frac{1}{c_2} f(n) \le g(n) \le \frac{1}{c_1} f(n)
    \]
    Since $c_1$ and $c_2$ are strictly positive constants, $\frac{1}{c_2}$ and $\frac{1}{c_1}$ are also strictly positive constants. This fits the definition of $g(n) \in \Theta(f(n))$.

    \item \textbf{Transitivity} (If $f(n) \in \Theta(g(n))$ and $g(n) \in \Theta(h(n))$, then $f(n) \in \Theta(h(n))$):
    From the definitions, there exist positive constants such that:
    \[
        c_1 g(n) \le f(n) \le c_2 g(n) \quad \text{for all } n \ge n_1
    \]
    \[
        c_3 h(n) \le g(n) \le c_4 h(n) \quad \text{for all } n \ge n_2
    \]
    Combining these inequalities for $n \ge \max(n_1, n_2)$, we substitute $g(n)$:
    \[
        c_1(c_3 h(n)) \le c_1 g(n) \le f(n) \le c_2 g(n) \le c_2(c_4 h(n))
    \]
    This simplifies to:
    \[
        (c_1 c_3) h(n) \le f(n) \le (c_2 c_4) h(n)
    \]
    Since $c_1, c_2, c_3, c_4$ are all positive constants, their products $c_1 c_3$ and $c_2 c_4$ are also positive constants. Thus, $f(n) \in \Theta(h(n))$.
\end{enumerate}

Since the relationship is reflexive, symmetric, and transitive, $\Theta$ is an \textbf{equivalence relation}. $\blacksquare$

